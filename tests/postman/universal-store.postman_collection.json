{
  "info": {
    "name": "Universal Store APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Catalog",
      "item": [
        {
          "name": "GET /catalog",
          "request": {
            "method": "GET",
            "url": "{{catalogUrl}}/catalog"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('returns an array', () => pm.expect(body).to.be.an('array'));",
                  "pm.test('has seeded catalog items', () => pm.expect(body.length).to.be.at.least(4));",
                  "pm.test('items have required fields', () => {",
                  "  body.forEach(item => {",
                  "    pm.expect(item).to.have.property('sku');",
                  "    pm.expect(item).to.have.property('title');",
                  "    pm.expect(item).to.have.property('price');",
                  "    pm.expect(item).to.have.property('image');",
                  "  });",
                  "});",
                  "pm.collectionVariables.set('catalogSkus', JSON.stringify(body.map(i => i.sku)));"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /catalog/:sku (exists)",
          "request": {
            "method": "GET",
            "url": "{{catalogUrl}}/catalog/111111"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('returns Pen', () => {",
                  "  const item = pm.response.json();",
                  "  pm.expect(item.sku).to.eql('111111');",
                  "  pm.expect(item.title).to.eql('Pen');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /catalog/:sku (404)",
          "request": {
            "method": "GET",
            "url": "{{catalogUrl}}/catalog/does-not-exist"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Inventory",
      "item": [
        {
          "name": "GET /inventory",
          "request": {
            "method": "GET",
            "url": "{{inventoryUrl}}/inventory"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('returns an array', () => pm.expect(body).to.be.an('array'));",
                  "pm.test('has seeded inventory items', () => pm.expect(body.length).to.be.at.least(4));",
                  "pm.test('items have sku and quantity', () => {",
                  "  body.forEach(item => {",
                  "    pm.expect(item).to.have.property('sku');",
                  "    pm.expect(item).to.have.property('quantity');",
                  "  });",
                  "});",
                  "const marker = body.find(i => i.sku === '444444');",
                  "pm.test('444444 is out of stock in seed data', () => pm.expect(marker.quantity).to.eql(0));"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /inventory/:sku",
          "request": {
            "method": "GET",
            "url": "{{inventoryUrl}}/inventory/111111"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('returns array with quantity 3', () => {",
                  "  pm.expect(body).to.be.an('array');",
                  "  pm.expect(body[0].quantity).to.eql(3);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Contract",
      "item": [
        {
          "name": "Every inventory SKU exists in catalog",
          "request": {
            "method": "GET",
            "url": "{{inventoryUrl}}/inventory"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const inventory = pm.response.json();",
                  "const catalogSkus = JSON.parse(pm.collectionVariables.get('catalogSkus'));",
                  "inventory.forEach(item => {",
                  "  pm.test(`inventory sku ${item.sku} exists in catalog`, () => {",
                  "    pm.expect(catalogSkus).to.include(item.sku);",
                  "  });",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}