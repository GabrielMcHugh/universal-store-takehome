# Optional overrides for docker compose. Copy to `.env` when needed.
# Without a `.env` file, defaults use localhost (local Docker on desktop).
#
# GitHub Codespaces: copy this file to `.env` and set your forwarded port URLs
# (no trailing slash). Open the app via the 8080 URL, not localhost.

# CLIENT_URL=http://localhost:8080
# REACT_APP_CATALOG_URL=http://localhost:3000
# REACT_APP_INVENTORY_URL=http://localhost:4000

# CLIENT_URL=https://YOUR-CODESPACE-8080.app.github.dev
# REACT_APP_CATALOG_URL=https://YOUR-CODESPACE-3000.app.github.dev
# REACT_APP_INVENTORY_URL=https://YOUR-CODESPACE-4000.app.github.dev
